{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["alpharequest"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datenquelle",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AlphaRequest – Übersicht",
  "uid": "alpharequest-overview",
  "version": 2,
  "weekStart": "",
  "panels": [
    { "id": 100, "type": "row", "title": "Überblick", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },

    {
      "id": 1, "type": "stat", "title": "Aktive Sessions",
      "description": "Aktuell aktive Sessions (Quelle: active_sessions-Tabelle).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#3EACB6" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "#3EACB6", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [ { "refId": "A", "expr": "auth_sessions_active", "legendFormat": "Sessions" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Nutzer online",
      "description": "Verschiedene Nutzer mit mindestens einer aktiven Session.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#3EACB6" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "#3EACB6", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [ { "refId": "A", "expr": "auth_users_online", "legendFormat": "Nutzer" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Offene Tickets",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#3EACB6" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "#3EACB6", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [ { "refId": "A", "expr": "tickets_open", "legendFormat": "Offen" } ]
    },
    {
      "id": 4, "type": "stat", "title": "Tickets gesamt",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#084C59" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "#084C59", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [ { "refId": "A", "expr": "tickets_total", "legendFormat": "Gesamt" } ]
    },
    {
      "id": 5, "type": "stat", "title": "Login-Fehler (1h)",
      "description": "Fehlgeschlagene Logins in der letzten Stunde.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "targets": [ { "refId": "A", "expr": "sum(increase(auth_login_failed_total[1h]))", "legendFormat": "Fehler" } ]
    },
    {
      "id": 6, "type": "stat", "title": "Mailfehler (1h)",
      "description": "Mailversand-Fehler (Graph) in der letzten Stunde.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "targets": [ { "refId": "A", "expr": "sum(increase(mail_sent_total{status=\"error\"}[1h]))", "legendFormat": "Fehler" } ]
    },

    { "id": 101, "type": "row", "title": "Tickets", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "panels": [] },

    {
      "id": 10, "type": "piechart", "title": "Tickets nach Status",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "pieType": "donut", "tooltip": { "mode": "single", "sort": "none" }, "legend": { "displayMode": "list", "placement": "right", "showLegend": true, "values": ["value"] }, "displayLabels": ["percent"] },
      "targets": [ { "refId": "A", "expr": "tickets_by_status", "legendFormat": "{{status}}" } ]
    },
    {
      "id": 16, "type": "piechart", "title": "Tickets nach Priorität",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "pieType": "donut", "tooltip": { "mode": "single", "sort": "none" }, "legend": { "displayMode": "list", "placement": "right", "showLegend": true, "values": ["value"] }, "displayLabels": ["percent"] },
      "targets": [ { "refId": "A", "expr": "tickets_by_priority", "legendFormat": "{{priority}}" } ]
    },
    {
      "id": 11, "type": "bargauge", "title": "Tickets nach Typ",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#3EACB6" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "#3EACB6", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "color" },
      "targets": [ { "refId": "A", "expr": "tickets_by_type", "legendFormat": "{{type}}" } ]
    },
    {
      "id": 12, "type": "bargauge", "title": "Offene Tickets nach aktueller Phase",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#3EACB6" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "#3EACB6", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "color" },
      "targets": [ { "refId": "A", "expr": "tickets_by_phase", "legendFormat": "{{phase}}" } ]
    },
    {
      "id": 13, "type": "bargauge", "title": "Offen je Fachabteilung",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#3EACB6" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "#3EACB6", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "color" },
      "targets": [ { "refId": "A", "expr": "tickets_open_by_department", "legendFormat": "{{department}}" } ]
    },
    {
      "id": 14, "type": "bargauge", "title": "Ältestes offenes Ticket je Phase",
      "description": "Alter des am längsten offenen Tickets je Phase. Amber ab 1 Tag, rot ab 3 Tagen.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 86400 }, { "color": "red", "value": 259200 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "color" },
      "targets": [ { "refId": "A", "expr": "tickets_oldest_open_age_seconds", "legendFormat": "{{phase}}" } ]
    },
    {
      "id": 15, "type": "timeseries", "title": "Durchsatz (letzte Stunde)",
      "description": "Erstellte, abgeschlossene und abgelehnte Tickets, jeweils Anzahl in der zurückliegenden Stunde.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never", "pointSize": 5, "axisPlacement": "auto", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "none", "group": "A" }, "spanNulls": false } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "abgelehnt" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "abgeschlossen" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "erstellt" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3EACB6" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "sum(increase(tickets_created_total[1h]))", "legendFormat": "erstellt" },
        { "refId": "B", "expr": "sum(increase(tickets_terminal_total{outcome=\"archived\"}[1h]))", "legendFormat": "abgeschlossen" },
        { "refId": "C", "expr": "sum(increase(tickets_terminal_total{outcome=\"rejected\"}[1h]))", "legendFormat": "abgelehnt" }
      ]
    },

    { "id": 102, "type": "row", "title": "Auth & Sessions", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }, "panels": [] },

    {
      "id": 20, "type": "timeseries", "title": "Sessions & Nutzer online",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 12, "gradientMode": "opacity", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "none", "group": "A" }, "spanNulls": false } },
        "overrides": [ { "matcher": { "id": "byName", "options": "Sessions" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3EACB6" } } ] } ]
      },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "auth_sessions_active", "legendFormat": "Sessions" },
        { "refId": "B", "expr": "auth_users_online", "legendFormat": "Nutzer online" }
      ]
    },
    {
      "id": 21, "type": "timeseries", "title": "Logins (letzte Stunde)",
      "description": "Anzahl der Logins in der jeweils zurückliegenden Stunde (Versuche, Erfolg, Fehler).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "none", "group": "A" }, "spanNulls": false } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Fehler" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "Erfolg" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "sum(increase(auth_login_attempts_total[1h]))", "legendFormat": "Versuche" },
        { "refId": "B", "expr": "sum(increase(auth_logins_success_total[1h]))", "legendFormat": "Erfolg" },
        { "refId": "C", "expr": "sum(increase(auth_login_failed_total[1h]))", "legendFormat": "Fehler" }
      ]
    },
    {
      "id": 22, "type": "timeseries", "title": "Login-Fehler nach Grund (letzte Stunde)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "gradientMode": "none", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (reason) (increase(auth_login_failed_total[1h]))", "legendFormat": "{{reason}}" } ]
    },
    {
      "id": 23, "type": "timeseries", "title": "Force-Logouts nach Scope (letzte Stunde)",
      "description": "Admin-initiierte Zwangs-Abmeldungen: session (einzeln) / user (pro Person) / others (alle anderen).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "gradientMode": "none", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (scope) (increase(session_force_logouts_total[1h]))", "legendFormat": "{{scope}}" } ]
    },

    { "id": 103, "type": "row", "title": "E-Mail", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 }, "panels": [] },

    {
      "id": 30, "type": "timeseries", "title": "Mailversand nach Typ (letzte Stunde)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "none", "group": "A" }, "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (type) (increase(mail_sent_total[1h]))", "legendFormat": "{{type}}" } ]
    },
    {
      "id": 31, "type": "timeseries", "title": "Mail: Erfolg vs. Fehler (letzte Stunde)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "none", "group": "A" }, "spanNulls": false } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "sent" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (status) (increase(mail_sent_total[1h]))", "legendFormat": "{{status}}" } ]
    },

    { "id": 104, "type": "row", "title": "HTTP", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 }, "panels": [] },

    {
      "id": 40, "type": "timeseries", "title": "Request-Rate nach Status",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 12, "gradientMode": "opacity", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "normal", "group": "A" }, "spanNulls": false } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "5.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byRegexp", "options": "4.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (status) (rate(http_requests_total[$__rate_interval]))", "legendFormat": "{{status}}" } ]
    },
    {
      "id": 41, "type": "timeseries", "title": "HTTP-Latenz (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never", "scaleDistribution": { "type": "linear" }, "stacking": { "mode": "none", "group": "A" }, "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 42, "type": "timeseries", "title": "5xx-Fehlerrate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 56 },
